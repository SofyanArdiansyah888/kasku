# Salin ke .env sebelum deploy:
#   cp env.prod.example .env
#
# Password dengan karakter $ — bungkus single quote:
#   POSTGRES_PASSWORD='U#8vP!2mK@9qL$5xT&7nZ'
#
# Jika error "password authentication failed" setelah ubah .env:
#   Volume Postgres sudah ter-init dengan password lama. Pilih salah satu:
#   A) Reset password (data tetap):
#      docker compose exec postgres psql -U kasku -d postgres \
#        -c "ALTER USER kasku WITH PASSWORD 'password-baru-sama-dengan-env';"
#      docker compose restart api
#   B) Hapus volume & buat ulang (data hilang):
#      docker compose down -v && docker compose up -d --build

# Database (POSTGRES_PASSWORD dipakai postgres + api)
DB_USER=kasku
DB_NAME=kasku
POSTGRES_PASSWORD=ganti-dengan-password-kuat

# Akses PostgreSQL remote
DB_PUBLISH_HOST=0.0.0.0
DB_PUBLISH_PORT=5432

# Backend
JWT_SECRET=ganti-dengan-string-acak-panjang-minimal-32-karakter
JWT_EXPIRY=24h
CORS_ORIGIN=https://kasku.jismo-educational.org
