# Salin ke .env sebelum deploy:
#   cp env.prod.example .env
#   cp secrets.env.example secrets.env
#
# Password & JWT — hanya di secrets.env (lihat secrets.env.example)
#
# Jika volume postgres sudah pernah dibuat dengan password lama:
#   chmod +x scripts/sync-db-password.sh && ./scripts/sync-db-password.sh

# Database
DB_USER=kasku
DB_NAME=kasku

# Akses PostgreSQL remote
DB_PUBLISH_HOST=0.0.0.0
DB_PUBLISH_PORT=5432

# Backend
JWT_EXPIRY=24h
CORS_ORIGIN=https://kasku.jismo-educational.org
