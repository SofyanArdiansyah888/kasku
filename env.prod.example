# Salin ke .env sebelum deploy:
#   cp env.prod.example .env
#
# Password dengan karakter $ — bungkus single quote:
#   POSTGRES_PASSWORD='pass$word123'
#
# Jika volume postgres SUDAH PERNAH dibuat dengan password lama, sinkronkan:
#   chmod +x scripts/sync-db-password.sh
#   ./scripts/sync-db-password.sh
#
# Atau reset total (data hilang):
#   docker compose down -v && docker compose up -d --build

# Database
DB_USER=kasku
DB_NAME=kasku
POSTGRES_PASSWORD=ganti-dengan-password-kuat

# Akses PostgreSQL remote
DB_PUBLISH_HOST=0.0.0.0
DB_PUBLISH_PORT=5432

# Backend
JWT_SECRET=ganti-dengan-string-acak-panjang-minimal-32-karakter
JWT_EXPIRY=24h
CORS_ORIGIN=https://kasku.jismo-educational.org
