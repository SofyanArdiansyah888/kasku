# Salin ke .env sebelum deploy:
#   cp env.prod.example .env
#
# PENTING — password dengan karakter $:
#   Docker Compose menginterpretasi $ sebagai variabel.
#   Bungkus dengan single quote, contoh:
#   DB_PASSWORD='U#8vP!2mK@9qL$5xT&7nZ'
#   Atau escape: DB_PASSWORD=pass$$word

# Database
DB_USER=kasku
DB_PASSWORD='ganti-dengan-password-kuat'
DB_NAME=kasku

# Akses PostgreSQL remote
DB_PUBLISH_HOST=0.0.0.0
DB_PUBLISH_PORT=5432

# Backend
JWT_SECRET='ganti-dengan-string-acak-panjang-minimal-32-karakter'
JWT_EXPIRY=24h
CORS_ORIGIN=https://kasku.jismo-educational.org
