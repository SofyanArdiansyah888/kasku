# Salin ke .env sebelum deploy:
#   cp env.prod.example .env

# Database
DB_USER=kasku
DB_PASSWORD=ganti-dengan-password-kuat
DB_NAME=kasku

# Akses PostgreSQL dari luar server (DBeaver, pgAdmin, dll.)
# - 127.0.0.1 = hanya dari server itu sendiri (remote via SSH tunnel)
# - 0.0.0.0     = dari IP manapun (buka firewall + gunakan password kuat)
DB_PUBLISH_HOST=0.0.0.0
DB_PUBLISH_PORT=5432

# Backend
JWT_SECRET=ganti-dengan-string-acak-panjang-minimal-32-karakter
JWT_EXPIRY=24h
CORS_ORIGIN=https://kasku.jismo-educational.org

# ─── Koneksi remote (contoh) ───
# Host:     IP/domain server Anda
# Port:     5432  (atau nilai DB_PUBLISH_PORT)
# Database: kasku
# User:     kasku
# Password: (nilai DB_PASSWORD)
# URL:      postgresql://kasku:PASSWORD@SERVER_IP:5432/kasku
