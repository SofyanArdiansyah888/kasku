# Salin ke secrets.env (file ini aman untuk password dengan karakter $):
#   cp secrets.env.example secrets.env
#
# Karakter $ harus di-escape dengan $$ (contoh: pass$$Wm8 = pass$Wm8)
# JANGAN simpan password di .env — Compose akan parse $ sebagai variabel.

POSTGRES_PASSWORD=ganti-dengan-password-kuat
JWT_SECRET=ganti-dengan-string-acak-panjang-minimal-32-karakter
